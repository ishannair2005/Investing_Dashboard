# Copy this file to .env and fill in your own values. Never commit .env.

# --------------------------------------------------------------------------
# Deployment mode
# --------------------------------------------------------------------------
# Leave as true on your local Mac. If deploying dashboard_app.py to
# Streamlit Community Cloud, set this to false in that deployment's
# Secrets panel -- it switches the dashboard to a read-only view (no
# add/remove company, no Watchlist editing), since the cloud instance's
# filesystem is ephemeral and has no git push access to persist edits.
IS_LOCAL_INSTANCE=true

# --------------------------------------------------------------------------
# Output workbook
# --------------------------------------------------------------------------
# Local .xlsx file the dashboard reads/writes. Defaults to the project
# root if left blank. Change this if you want the file to live somewhere
# else, e.g. a synced Dropbox/iCloud folder.
EXCEL_FILE_PATH=

# --------------------------------------------------------------------------
# AI provider (analysis.py) — set AI_PROVIDER to "anthropic" or "openai"
# and fill in the matching key. Only one is required at a time.
# --------------------------------------------------------------------------
AI_PROVIDER=anthropic
AI_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --------------------------------------------------------------------------
# Network / retry behavior
# --------------------------------------------------------------------------
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=2.0
REQUEST_TIMEOUT_SECONDS=30

# --------------------------------------------------------------------------
# News
# --------------------------------------------------------------------------
NEWS_LOOKBACK_DAYS=7
MAX_NEWS_ITEMS_PER_TICKER=10

# --------------------------------------------------------------------------
# Logging
# --------------------------------------------------------------------------
LOG_LEVEL=INFO
