# Copy this file to .env and fill in your own values. Never commit .env.

# --------------------------------------------------------------------------
# Deployment mode
# --------------------------------------------------------------------------
# Leave as true on your local Mac. If deploying dashboard_app.py to
# Streamlit Community Cloud, set this to false in that deployment's
# Secrets panel. Combined with GITHUB_TOKEN below, this determines
# whether write actions (add/remove company, edit Watchlist) are shown:
# always on locally; on a deployed instance only if GITHUB_TOKEN is also
# set, since that instance has no git credentials of its own otherwise.
IS_LOCAL_INSTANCE=true

# A GitHub fine-grained Personal Access Token, repo-scoped to just this
# repo with "Contents: Read and write" permission -- lets a deployed
# (non-local) instance commit and push its own changes back to GitHub.
# Leave blank locally; set only in the Streamlit Community Cloud
# deployment's Secrets panel if you want write actions enabled there.
GITHUB_TOKEN=
GITHUB_REPO=ishannair2005/Investing_Dashboard

# --------------------------------------------------------------------------
# Output workbook
# --------------------------------------------------------------------------
# Local .xlsx file the dashboard reads/writes. Defaults to the project
# root if left blank. Change this if you want the file to live somewhere
# else, e.g. a synced Dropbox/iCloud folder.
EXCEL_FILE_PATH=

# --------------------------------------------------------------------------
# AI provider (analysis.py) — set AI_PROVIDER to "anthropic" or "openai"
# and fill in the matching key. Only one is required at a time.
# --------------------------------------------------------------------------
AI_PROVIDER=anthropic
AI_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Per-request timeout for AI calls specifically (separate from the
# generic REQUEST_TIMEOUT_SECONDS below, since a full investment thesis
# can legitimately take longer than a lightweight yfinance call).
AI_REQUEST_TIMEOUT_SECONDS=120

# --------------------------------------------------------------------------
# Network / retry behavior
# --------------------------------------------------------------------------
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=2.0
REQUEST_TIMEOUT_SECONDS=30

# --------------------------------------------------------------------------
# News
# --------------------------------------------------------------------------
NEWS_LOOKBACK_DAYS=7
MAX_NEWS_ITEMS_PER_TICKER=10

# --------------------------------------------------------------------------
# Logging
# --------------------------------------------------------------------------
LOG_LEVEL=INFO
